model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["inventory demandforecast","inventory inventory","inventory inventorytransactions","inventory purchaseorderitems","inventory purchaseorders","inventory warehouses","product product","product productcategory","supplychain productsuppliers","supplychain suppliers","supplychain supplychainevents","ServerParameter","DatabaseParameter"]

ref table 'inventory demandforecast'
ref table 'inventory inventory'
ref table 'inventory inventorytransactions'
ref table 'inventory purchaseorderitems'
ref table 'inventory purchaseorders'
ref table 'inventory warehouses'
ref table 'product product'
ref table 'product productcategory'
ref table 'supplychain productsuppliers'
ref table 'supplychain suppliers'
ref table 'supplychain supplychainevents'

ref cultureInfo en-US

